# LLM provider -- Anthropic (paid) or NVIDIA's hosted API (has a free tier)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5

NVIDIA_API_KEY=nvapi-...
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# "anthropic" (default, real Claude calls, costs money), "nvidia" (real
# calls against NVIDIA's hosted API, free-tier friendly), or "demo"
# (deterministic canned responses -- lets you run the full real pipeline,
# real events, real frontend end-to-end with no API key/cost). Production
# deployments must leave this at "anthropic".
LLM_PROVIDER=anthropic

# Long-term + semantic memory share one database (Postgres in a server
# deployment, or SQLite locally e.g. sqlite:///./aio_local.db). Semantic
# (vector) search is backed by this same database -- no Qdrant / vector-DB
# server needed; see src/aio/memory/semantic.py.
DATABASE_URL=postgresql+psycopg2://aio:aio@localhost:5432/aio

# Logical namespace for project embeddings within the database above.
SEMANTIC_COLLECTION=aio_projects

# API
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated origins allowed to call the API (the Next.js frontend's URL)
CORS_ORIGINS_RAW=http://localhost:3000
